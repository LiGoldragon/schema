{
  Text@{ String }
  Identifier@{ Integer }
  Topic@{ @Text }
  Topics@{ (Vec Topic) }
  TopicIndex@{ entries@(Map (Topic Identifier)) }
  Kind@[Decision Principle Correction Clarification Constraint]
  Entry@{ @Topics @Kind description@Text related@TopicIndex maybeTopic@(Optional Topic) }
  RecordQuery@{ topics@(Vec Topic) maximumCount@Integer }
  RecordReply@{ entries@(Vec Entry) }
  SpiritInput@[Record@Entry Observe@RecordQuery Ping]
  SpiritOutput@[Recorded@Identifier Observed@RecordReply Pong]
}
