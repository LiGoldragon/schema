{
  Topic@{ String }
  Topics@{ (Vec Topic) }
  Kind@[Decision Correction]
  Description@{ String }
  Entry@{ @Topics @Kind @Description }
  Query@{ @Topics limit@(Optional Integer) }
  SomethingHoldingSomething@{ String }
  SomeEnum@[ (SomethingHoldingSomething SomethingHoldingSomething) SomethingElse (SomeString String) ]
}
